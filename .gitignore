# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/playwright-report
/test-results/
/test-results
/blob-report/
/playwright/.cache/
/tests/screenshots/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.*.local
.env*
!.env.example
!.env*.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Real family drafts / private review notes (keep local only)
/family-data/family-import-draft.json
/family-data/CURRENT_TEST_DATA_AUDIT.md
/family-data/FAMILY_REVIEW.md

# Optional local seed overrides (use seed.example.sql in the repo)
/supabase/seed.sql

# Local editor / OS noise
*.swp
*~
.cursor/
